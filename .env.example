# === LLM API Keys ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
Z_AI_API_KEY=
MINIMAX_API_KEY=
TOGETHER_API_KEY=

# === Порты на хосте (docker compose) — меняйте, если порты заняты ===
POSTGRES_PORT=5432
REDIS_PORT=6379
# ChromaDB: хостовый порт (проброс "CHROMADB_HOST_PORT:8000" в образ)
CHROMADB_HOST_PORT=8100
# Порт Chroma ВНУТРИ контейнера (образ по умолчанию 8000) — в compose передаётся в app как CHROMADB_PORT
CHROMADB_INTERNAL_PORT=8000
LANGFUSE_PORT=3001

# === Database ===
DATABASE_URL=postgresql+asyncpg://agents:agents@postgres:5432/agents

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === ChromaDB ===
CHROMADB_HOST=chromadb
# Для приложения (pydantic): порт подключения к Chroma. В Docker задаётся через
# CHROMADB_INTERNAL_PORT в compose; при локальном запуске без Docker — этот порт.
CHROMADB_PORT=8000
#
# Почему CHROMADB_HOST_PORT (например 8100) и CHROMADB_PORT/INTERNAL (8000) разные:
#   • HOST_PORT — что слушает ваш ПК (localhost:8100 → проброс в контейнер).
#   • 8000 — что слушает процесс Chroma внутри контейнера (так задано в образе).
# Совпадать они не должны: это разные «концы» проброса портов.

# === Docker Sandbox ===
DOCKER_HOST=tcp://docker-dind:2376
DOCKER_TLS_VERIFY=1
DOCKER_CERT_PATH=/certs/client

# === Langfuse Observability ===
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# === LLM Config ===
LLM_CONFIG_PATH=/app/llm_config.yaml

# === App Settings ===
# Порт HTTP-сервера (по умолчанию 8000; смените, если порт занят)
APP_PORT=8005
LOG_LEVEL=INFO
MAX_CONCURRENT_TASKS=5
